# MiniMax API key (get one at https://platform.minimax.io)
VITE_MINIMAX_API_KEY=your_api_key_here

# Supabase (create a project at https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Google Calendar (optional – for "Import from Google Calendar" in the study plan form)
# 1. Enable Google Calendar API in Google Cloud Console.
# 2. Create OAuth 2.0 credentials (Web application) and add your origin to Authorized JavaScript origins.
# 3. Create an API key for the same project (optional, for quota).
VITE_GOOGLE_CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_google_api_key
